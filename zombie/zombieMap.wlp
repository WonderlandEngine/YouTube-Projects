    "settings": {
        "project": {
            "name": "ZombieMap",
            "version": [
                1,
                5,
                2
            ]
        },
        "xr": {
            "leftEyeObject": "18",
            "rightEyeObject": "19",
            "webxr": {
                "optionalFeatures": {
                    "local-floor": true
                }
            }
        },
        "scripting": {
            "application": {
                "output": "ThirdPersonShooter-app.js",
                "bundling": "esbuild"
            },
            "components": {
                "output": "ThirdPersonShooter-bundle.js",
                "sourcePaths": [
                    "js/",
                    "js/debugs",
                    "js/weapons",
                    "js/scarecrow",
                    "js/zombie"
                ]
            }
        },
        "runtime": {
            "visualizeColliders": false,
            "visualizePhysX": false,
            "loadUncompressedImagesAsBitmap": false
        },
        "rendering": {
            "environment": {
                "enabled": false,
                "image": "336",
                "intensity": 1.0,
                "mode": "spherical-harmonic-2",
                "bakingMode": "image"
            },
            "sky": {
                "enabled": true,
                "material": "421"
            },
            "bloom": {
                "threshold": 1.1,
                "enabled": true,
                "width": 1.0,
                "passes": 2
            },
            "compressedTextureAtlasSize": [
                16384,
                8192
            ],
            "shadowMapSize": [
                2048,
                2048
            ],
            "textureAtlasSize": [
                4096,
                4096
            ],
            "maxTextures": 512
        },
        "physx": {
            "enable": true
        },
        "editor": {
            "camera": {
                "far": 1000.0
            }
        }
    },
