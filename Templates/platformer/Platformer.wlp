    "settings": {
        "project": {
            "name": "Platformer",
            "version": [
                1,
                4,
                5
            ]
        },
        "xr": {
            "leftEyeObject": "18",
            "rightEyeObject": "19",
            "webxr": {
                "optionalFeatures": {
                    "local-floor": true
                }
            },
            "vr": {
                "enable": true
            }
        },
        "scripting": {
            "application": {
                "output": "ThirdPersonShooter-app.js",
                "bundling": "esbuild"
            },
            "components": {
                "output": "ThirdPersonShooter-bundle.js",
                "sourcePaths": [
                    "js/",
                    "js/debugs",
                    "js/weapons",
                    "js/scarecrow"
                ]
            }
        },
        "runtime": {
            "visualizeColliders": false,
            "visualizePhysX": false
        },
        "rendering": {
            "environment": {
                "enabled": true,
                "image": "336",
                "intensity": 0.8,
                "mode": "spherical-harmonic-2",
                "bakingMode": "sky",
                "material": "339"
            },
            "sky": {
                "enabled": true,
                "material": "339"
            },
            "hdr": {
                "exposure": 1.5,
                "tonemapping": "none"
            },
            "bloom": {
                "enabled": false,
                "intensity": 1.0,
                "threshold": 0.99,
                "width": 2.5
            }
        },
        "physx": {
            "enable": true
        },
        "editor": {
            "camera": {
                "far": 1000.0
            }
        }
    },
